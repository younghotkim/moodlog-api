# Mood Log API - Environment Variables
NODE_ENV=production
PORT=5000

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Security
JWT_SECRET=your_jwt_secret_here_minimum_32_characters
SESSION_SECRET=your_session_secret_here_minimum_32_characters

# CORS (토스 인앱 도메인)
CORS_ORIGINS=https://moodlog.apps.tossmini.com,https://moodlog.private-apps.tossmini.com,http://localhost:3001

# Toss Login (Apps in Toss)
TOSS_API_BASE_URL=https://apps-in-toss-api.toss.im
TOSS_AES_KEY=your_base64_encoded_aes_256_key_from_toss_console
TOSS_AAD=your_aad_string_from_toss_console

# Toss Unlink Callback Basic Auth (콘솔에서 설정한 username/password와 동일하게)
TOSS_CALLBACK_USERNAME=your_callback_username
TOSS_CALLBACK_PASSWORD=your_callback_password
